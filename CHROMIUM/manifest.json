{
  "manifest_version": 3,
  "name": "MarkAndFind",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "author": "Martin Polomský",
  "homepage_url": "https://github.com/Mar-Pol/MarkAndFind",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "contextMenus",
    "scripting",
    "alarms"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "browser-polyfill.min.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "search-selected": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "MacCtrl+Shift+F"
      },
      "description": "__MSG_cmdSearch__"
    }
  },
  "icons": {
    "48": "icons/icon.png"
  }
}